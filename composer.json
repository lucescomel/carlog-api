{
  "name": "luc/carlog-api",
  "description": "Car maintenance API (Symfony 7 + API Platform + PostgreSQL)",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": ">=8.2",
    "ext-ctype": "*",
    "ext-iconv": "*",
    "api-platform/core": "^3.3",
    "doctrine/doctrine-bundle": "^2.12",
    "doctrine/doctrine-migrations-bundle": "^3.4",
    "doctrine/orm": "^2.18",
    "nelmio/cors-bundle": "^2.4",
    "symfony/console": "^7.1",
    "symfony/dotenv": "^7.1",
    "symfony/framework-bundle": "^7.1",
    "symfony/monolog-bundle": "^3.8",
    "symfony/twig-bundle": "^6.4 || ^7.0",
    "symfony/asset": "^6.4 || ^7.0",
    "symfony/runtime": "^7.1",
    "symfony/serializer": "^7.1",
    "symfony/validator": "^7.1",
    "symfony/yaml": "^7.1",
    "twig/twig": "^3.0"
  },
  "require-dev": {
    "doctrine/doctrine-fixtures-bundle": "^3.5",
    "symfony/asset": "^7.1",
    "symfony/maker-bundle": "^1.61",
    "symfony/twig-bundle": "^7.1",
    "symfony/var-dumper": "^7.1"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true
    },
    "platform": {
      "php": "8.3.9"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
